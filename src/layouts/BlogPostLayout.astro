---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { formatDate, postDescription, readingMinutes, getRelatedPosts, displayTitle, type Post } from "@lib/posts";
import { SITE } from "@lib/site";

interface Props { post: Post; readMin?: number }
const { post, readMin = 3 } = Astro.props;
const { date, featuredImage, featuredImageAlt, author } = post.data;
const title = displayTitle(post);
const related = await getRelatedPosts(post, 3);
const desc = postDescription(post);

const jsonld = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  datePublished: date.toISOString(),
  description: desc,
  image: featuredImage ? new URL(featuredImage, SITE.url).href : undefined,
  author: { "@type": "Organization", name: SITE.name },
  publisher: { "@type": "Organization", name: SITE.name },
  mainEntityOfPage: new URL(`/${post.id}/`, SITE.url).href,
};
---
<BaseLayout title={post.data.metaTitle || title} description={desc} type="article" image={featuredImage}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} is:inline />

  <article>
    <!-- White header with red left border accent -->
    <header class="bg-white border-b border-gray-100">
      <Container class="max-w-2xl py-8">
        <!-- Breadcrumb -->
        <nav class="text-xs text-slate-400 mb-5 flex items-center gap-1.5" aria-label="Kruimelpad">
          <a href="/" class="hover:text-slate-600 transition-colors">Home</a>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          <a href="/blog/" class="hover:text-slate-600 transition-colors">Blog</a>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          <span class="text-slate-500 line-clamp-1">{title}</span>
        </nav>

        <div class="border-l-4 border-red-500 pl-5">
          <h1 class="text-2xl font-extrabold tracking-tight leading-snug text-slate-900 sm:text-3xl lg:text-4xl">
            {title}
          </h1>
        </div>

        <!-- Meta -->
        <div class="mt-4 flex flex-wrap items-center gap-3">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-orange-50 border border-orange-100 px-3 py-1 text-xs font-semibold text-orange-700">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            <time datetime={date.toISOString()}>{formatDate(date)}</time>
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-50 border border-gray-100 px-3 py-1 text-xs font-semibold text-slate-600">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            {readMin} min lezen
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-red-50 border border-red-100 px-3 py-1 text-xs font-semibold text-red-700">
            Rijbewijs B
          </span>
        </div>
      </Container>
    </header>

    <!-- Artikel content -->
    <Container class="max-w-2xl">
      {featuredImage && (
        <div class="pt-8 pb-2">
          <img
            src={featuredImage}
            alt={featuredImageAlt || title}
            width="800" height="450"
            loading="eager" fetchpriority="high" decoding="sync"
            class="w-full h-56 sm:h-72 object-cover rounded-xl shadow-md"
          />
        </div>
      )}
      <div class={`article-prose ${featuredImage ? 'pt-6' : 'pt-8'} pb-(--spacing-section)`}>
        <slot />
      </div>

      <!-- Inline CTA -->
      <div class="my-8 rounded-xl bg-orange-50 border-l-4 border-red-500 p-6 flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="flex-1">
          <p class="font-bold text-slate-900">Haal je rijbewijs zo snel mogelijk!</p>
          <p class="text-sm text-slate-600 mt-0.5">Bekijk alle tips en uitleg — gratis, direct te lezen.</p>
        </div>
        <a href="/blog/" class="shrink-0 inline-flex items-center gap-1.5 rounded-lg bg-red-600 px-5 py-2.5 text-sm font-bold text-white hover:bg-red-700 transition-colors">
          Ga direct →
        </a>
      </div>

      <!-- Deel-rij -->
      <div class="border-t border-slate-200 pt-6 pb-(--spacing-section) flex items-center justify-between gap-4 text-sm text-slate-500">
        <span>Gepubliceerd door <strong class="text-slate-700">{SITE.name}</strong></span>
        <a href="/blog/" class="font-semibold text-red-600 hover:underline">← Terug naar alle artikelen</a>
      </div>
    </Container>
  </article>

  <!-- Gerelateerde artikelen -->
  {related.length > 0 && (
    <section class="border-t border-gray-100 bg-orange-50">
      <Container class="py-(--spacing-section)">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-extrabold text-slate-900">Lees ook</h2>
          <a href="/blog/" class="text-sm font-semibold text-red-600 hover:underline">Alle artikelen →</a>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((p) => <BlogPostCard post={p} />)}
        </div>
      </Container>
    </section>
  )}
</BaseLayout>

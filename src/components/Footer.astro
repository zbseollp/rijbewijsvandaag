---
import Container from "@components/Container.astro";
import CurrentYear from "@components/CurrentYear.astro";
import { SITE } from "@lib/site";
import { getRecentPosts, displayTitle } from "@lib/posts";
const recent = (await getRecentPosts(4)).map((p) => ({ slug: p.id, title: displayTitle(p) }));
---
<footer class="mt-(--spacing-section) border-t border-slate-200 bg-slate-50">
  <Container class="grid gap-10 py-12 md:grid-cols-12">
    <div class="md:col-span-4">
      <div class="flex items-center gap-2 font-display text-lg font-extrabold text-slate-900">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-white">A</span>
        {SITE.name}
      </div>
      <p class="mt-3 max-w-sm text-sm text-slate-600">
        {SITE.name} biedt gratis online oefenmateriaal voor je CBR theorie-examen:
        het CBR theorie-examen. Gratis oefenmateriaal voor auto, scooter en motor.
      </p>
    </div>

    <div class="md:col-span-2">
      <h3 class="text-sm font-semibold text-slate-900">Oefenen</h3>
      <ul class="mt-3 space-y-2 text-sm text-slate-600">
        {SITE.nav.map((i) => (
          <li><a class="hover:text-brand-700" href={i.href}>{i.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-2">
      <h3 class="text-sm font-semibold text-slate-900">Populair</h3>
      <ul class="mt-3 space-y-2 text-sm text-slate-600">
        {SITE.popular.map((i) => (
          <li><a class="hover:text-brand-700" href={i.href}>{i.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-2">
      <h3 class="text-sm font-semibold text-slate-900">Info</h3>
      <ul class="mt-3 space-y-2 text-sm text-slate-600">
        <li><a class="hover:text-brand-700" href="/over-ons/">Over ons</a></li>
        <li><a class="hover:text-brand-700" href="/contact/">Contact</a></li>
        <li><a class="hover:text-brand-700" href="/sitemap/">Sitemap</a></li>
      </ul>
    </div>

    <div class="md:col-span-2">
      <h3 class="text-sm font-semibold text-slate-900">Recente artikelen</h3>
      <ul class="mt-3 space-y-2 text-sm text-slate-600">
        {recent.map((p) => (
          <li><a class="hover:text-brand-700" href={`/${p.slug}/`}>{p.title}</a></li>
        ))}
      </ul>
    </div>
  </Container>

  <div class="border-t border-slate-200 py-5">
    <Container class="flex flex-col items-center justify-between gap-2 text-sm text-slate-500 sm:flex-row">
      <p>© <CurrentYear />&nbsp;{SITE.name}. Alle rechten voorbehouden.</p>
      <p>Gemaakt om je te laten slagen.</p>
    </Container>
  </div>
</footer>

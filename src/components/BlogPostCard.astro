---
import type { Post } from "@lib/posts";
import { displayTitle, displayDescription, formatDate } from "@lib/posts";
interface Props { post: Post; eager?: boolean }
const { post } = Astro.props;
const { date } = post.data;
const title = displayTitle(post);
const desc = displayDescription(post);
const href = `/${post.id}/`;
---
<article class="group relative bg-white rounded-lg border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all border-l-4 border-l-red-500 flex flex-col">
  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-center gap-2 mb-3">
      <span class="inline-flex items-center rounded-full bg-orange-50 px-2.5 py-0.5 text-xs font-semibold text-orange-700">Theorie</span>
      <time datetime={date.toISOString()} class="text-xs text-slate-400">{formatDate(date)}</time>
    </div>
    <h2 class="text-base font-bold text-slate-900 leading-snug group-hover:text-red-700 transition-colors flex-1">
      <a href={href} class="after:absolute after:inset-0">{title}</a>
    </h2>
    {desc && <p class="mt-2 text-sm text-slate-500 leading-relaxed line-clamp-2">{desc}</p>}
    <div class="mt-4 flex items-center gap-1 text-xs font-bold text-red-600 uppercase tracking-wide">
      Lees meer <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </div>
  </div>
</article>

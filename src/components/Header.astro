---
import Container from "@components/Container.astro";
import { SITE } from "@lib/site";
const path = new URL(Astro.request.url).pathname;
const isActive = (href: string) => href === "/" ? path === "/" : path.startsWith(href);
const navItems = SITE.nav.filter(i => i.href !== "/over-ons/" && i.href !== "/contact/");
---
<header class="bg-white border-b border-gray-200 shadow-sm sticky top-0 z-50">
  <Container class="flex h-16 items-center justify-between gap-6">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0 group">
      <div class="w-9 h-9 flex items-center justify-center shrink-0 rotate-45 overflow-hidden rounded-lg bg-red-600 group-hover:bg-red-700 transition-colors">
        <span class="text-white font-black text-lg leading-none -rotate-45">R</span>
      </div>
      <span class="font-black text-slate-900 text-base leading-tight hidden sm:block tracking-tight">
        Rijbewijs<span class="text-red-600">Vandaag</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-0.5" aria-label="Hoofdmenu">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-3 py-2 rounded-md text-sm font-medium transition-colors",
            isActive(item.href)
              ? "bg-orange-50 text-orange-700 font-semibold"
              : "text-slate-600 hover:text-red-700 hover:bg-orange-50",
          ]}
        >{item.label}</a>
      ))}
    </nav>

    <!-- CTA + hamburger -->
    <div class="flex items-center gap-2">
      <a href="/blog/" class="hidden lg:inline-flex items-center gap-1.5 rounded-lg bg-red-600 px-4 py-2 text-sm font-bold text-white hover:bg-red-700 transition-colors shadow-sm shadow-red-200">
        Begin nu <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <button
        data-menu-toggle
        class="inline-flex lg:hidden items-center justify-center rounded-md p-2 text-slate-600 hover:bg-orange-50"
        aria-label="Menu openen" aria-expanded="false"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </Container>

  <!-- Mobile menu -->
  <div data-mobile-menu class="hidden border-t border-gray-100 bg-white lg:hidden">
    <Container class="flex flex-col py-2">
      {SITE.nav.map((item) => (
        <a href={item.href} class:list={[
          "rounded-md px-3 py-2.5 text-sm font-medium",
          isActive(item.href) ? "text-red-700 bg-orange-50 font-semibold" : "text-slate-700 hover:bg-orange-50 hover:text-red-700"
        ]}>{item.label}</a>
      ))}
    </Container>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-menu-toggle]");
  const menu = document.querySelector("[data-mobile-menu]");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
</script>

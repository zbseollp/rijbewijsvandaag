---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import { SITE } from "@lib/site";
---
<BaseLayout
  title={`Theorie uitleg — verkeersregels begrijpen | ${SITE.name}`}
  description="Uitleg over verkeersregels, voorrangsregels, gevaarherkenning en alles wat je nodig hebt voor het CBR theorie-examen."
>
  <section class="bg-[linear-gradient(180deg,var(--color-brand-50)_0%,#fff_70%)]">
    <Container class="py-(--spacing-section)">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">Theorie uitleg</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-600">
        Begrijp de verkeersregels voordat je het examen ingaat. Hier vind je duidelijke uitleg over alle onderwerpen die terugkomen op het CBR theorie-examen.
      </p>
    </Container>
  </section>

  <Container class="py-(--spacing-section)">
    <div class="grid gap-8 md:grid-cols-2">
      {[
        { title: "Voorrangsregels", desc: "Wie heeft voorrang? Alles over kruispunten, haaientanden en voorrangsborden.", href: "/blog/" },
        { title: "Gevaarherkenning", desc: "Hoe herken je gevaarlijke situaties in het verkeer? Tips voor het examen.", href: "/blog/" },
        { title: "Verkeerstekens", desc: "Welke borden moet je kennen? Een overzicht van de belangrijkste verkeersborden.", href: "/blog/" },
        { title: "Rijstrookindeling", desc: "Wanneer gebruik je welke rijstrook? Alles over rijstroken en inhalen.", href: "/blog/" },
        { title: "Snelheidslimieten", desc: "Maximumsnelheden op verschillende wegsoorten in Nederland.", href: "/blog/" },
        { title: "Alcohollimiet & drugs", desc: "Wat zijn de regels rondom alcohol en drugs in het verkeer?", href: "/blog/" },
      ].map((item) => (
        <a href={item.href} class="group rounded-2xl border border-slate-200 bg-white p-7 transition hover:border-brand-300 hover:shadow-md">
          <h2 class="text-xl font-bold text-slate-900 group-hover:text-brand-700">{item.title}</h2>
          <p class="mt-2 text-slate-600">{item.desc}</p>
          <span class="mt-4 inline-block text-sm font-semibold text-brand-700">Lees meer →</span>
        </a>
      ))}
    </div>
  </Container>
</BaseLayout>

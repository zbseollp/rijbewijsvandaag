---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getHomepagePosts, displayTitle, displayDescription } from "@lib/posts";

const posts = await getHomepagePosts();
const [lead, ...rest] = posts;
const leadTitle = lead ? displayTitle(lead) : "";
const leadDesc = lead ? displayDescription(lead) : "";
---
<BaseLayout
  title="Blog — tips & info over je theorie-examen | Autotheorieoefenen"
  description="Artikelen en tips over het CBR theorie-examen, rijles, verkeersregels en alles rondom je rijbewijs."
>
  <section class="bg-[linear-gradient(180deg,var(--color-brand-50)_0%,#fff_60%)]">
    <Container class="py-(--spacing-section)">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Blog</h1>
      <p class="mt-3 max-w-2xl text-lg text-slate-600">Tips en informatie over je theorie-examen, rijles en alles rondom je rijbewijs.</p>
    </Container>
  </section>

  <Container class="pb-(--spacing-section)">
    {lead && (
      <a href={`/${lead.id}/`} class="group mb-10 grid overflow-hidden rounded-2xl border border-slate-200 bg-white md:grid-cols-2">
        {lead.data.featuredImage ? (
          <img src={lead.data.featuredImage} alt={lead.data.featuredImageAlt || leadTitle}
               width="800" height="450" loading="eager" fetchpriority="high" decoding="sync"
               class="aspect-video w-full object-cover" />
        ) : (
          <div class="relative flex aspect-video w-full items-center justify-center bg-gradient-to-br from-brand-600 to-brand-400">
            <span class="font-display text-3xl font-extrabold tracking-tight text-white/90">Autotheorie<span class="text-white">oefenen</span></span>
            <span class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.18),transparent_60%)]"></span>
          </div>
        )}
        <div class="flex flex-col justify-center p-7">
          <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">Uitgelicht</span>
          <h2 class="mt-2 text-2xl font-extrabold text-slate-900 group-hover:text-brand-700">{leadTitle}</h2>
          {leadDesc && <p class="mt-3 line-clamp-3 text-slate-600">{leadDesc}</p>}
        </div>
      </a>
    )}
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {rest.map((p) => <BlogPostCard post={p} />)}
    </div>
  </Container>
</BaseLayout>

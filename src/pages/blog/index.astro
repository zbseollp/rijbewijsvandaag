---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import { getHomepagePosts, displayTitle, displayDescription, formatDate } from "@lib/posts";
import { SITE } from "@lib/site";

const posts = await getHomepagePosts();
const featured = posts[0];
const rest = posts.slice(1);
---
<BaseLayout
  title={`Alle artikelen — theorie & rijbewijs tips | ${SITE.name}`}
  description="Alles over het CBR theorie-examen en rijbewijs B. Praktische uitleg, tips en voorbereiding."
>
  <!-- Blog header: red bg, all white text -->
  <section class="bg-red-700 text-white">
    <Container class="py-10">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-white/20 border border-white/30 px-3 py-1 text-xs font-bold text-white mb-4 uppercase tracking-wider">
            {posts.length} artikelen
          </div>
          <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">
            Rijbewijs theorie & tips
          </h1>
          <p class="mt-2 text-red-100 text-sm max-w-lg">Van voorrangsregels tot examentips — alles wat je nodig hebt om je rijbewijs B te halen.</p>
        </div>
        <a href="/rijbewijs-halen/" class="shrink-0 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-2.5 text-sm font-bold text-red-700 hover:bg-red-50 transition-colors shadow-md">
          Rijbewijs halen <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </Container>
  </section>

  <Container class="py-(--spacing-section)">

    <!-- Featured artikel: volledig breed, prominent -->
    {featured && (() => {
      const title = displayTitle(featured);
      const desc = displayDescription(featured);
      return (
        <a href={`/${featured.id}/`} class="group block rounded-2xl border-l-4 border-red-500 bg-white shadow-md hover:shadow-lg transition-shadow mb-10 overflow-hidden sm:flex">
          <!-- Color block linker kant -->
          <div class="shrink-0 w-full sm:w-2 bg-red-500"></div>
          <div class="flex-1 p-7 sm:p-8">
            <div class="flex items-center gap-3 mb-4">
              <span class="rounded-full bg-red-600 px-3 py-0.5 text-xs font-black text-white uppercase tracking-wide">Uitgelicht</span>
              <time class="text-xs text-slate-400">{formatDate(featured.data.date)}</time>
            </div>
            <h2 class="text-2xl font-black text-slate-900 group-hover:text-red-700 transition-colors leading-snug sm:text-3xl">{title}</h2>
            {desc && <p class="mt-3 text-slate-500 leading-relaxed max-w-2xl">{desc}</p>}
            <div class="mt-5 inline-flex items-center gap-1.5 text-sm font-bold text-red-600 uppercase tracking-wide">
              Lees het artikel <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      );
    })()}

    <!-- Divider met label -->
    <div class="flex items-center gap-4 mb-6">
      <span class="text-xs font-bold uppercase tracking-wider text-slate-400">Alle artikelen</span>
      <div class="flex-1 h-px bg-gray-100"></div>
      <span class="text-xs text-slate-400">{rest.length} meer</span>
    </div>

    <!-- Volledig brede 2-kolom grid, geen sidebar -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {rest.map((p, i) => {
        const title = displayTitle(p);
        const desc = displayDescription(p);
        return (
          <article class="group relative bg-white rounded-lg border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all border-l-4 border-l-red-500 flex flex-col">
            <div class="p-5 flex flex-col flex-1">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-mono text-red-300 font-bold">#{String(i + 2).padStart(2, '0')}</span>
                <time datetime={p.data.date.toISOString()} class="text-xs text-slate-400">{formatDate(p.data.date)}</time>
              </div>
              <h2 class="text-sm font-bold text-slate-900 leading-snug group-hover:text-red-700 transition-colors flex-1">
                <a href={`/${p.id}/`} class="after:absolute after:inset-0">{title}</a>
              </h2>
              {desc && <p class="mt-2 text-xs text-slate-500 leading-relaxed line-clamp-2">{desc}</p>}
              <div class="mt-3 flex items-center gap-1 text-xs font-bold text-red-600 uppercase tracking-wide">
                Lees meer <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-14 rounded-2xl bg-gray-900 text-white p-8 text-center">
      <h2 class="text-xl font-black tracking-tight mb-2">Klaar voor je examen?</h2>
      <p class="text-gray-400 text-sm mb-5">Bekijk onze theorie-uitleg en rijbewijs tips.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/theorie-uitleg/" class="inline-flex items-center gap-1.5 rounded-lg bg-red-600 px-5 py-2.5 text-sm font-bold text-white hover:bg-red-700 transition-colors">Theorie uitleg</a>
        <a href="/rijbewijs-halen/" class="inline-flex items-center gap-1.5 rounded-lg bg-gray-800 px-5 py-2.5 text-sm font-bold text-gray-100 hover:bg-gray-700 transition-colors">Rijbewijs halen</a>
      </div>
    </div>
  </Container>
</BaseLayout>

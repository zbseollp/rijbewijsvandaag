---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
const ACCESS_KEY = import.meta.env.WEB3FORMS_ACCESS_KEY || "4a9ea2ec-65de-4195-9a8c-ddcfb373975d";
---
<BaseLayout
  title="Contact | AutoTheorieGratisOefenen"
  description="Vragen, tips of feedback over AutoTheorieGratisOefenen? Neem contact met ons op via het formulier."
>
  <section class="bg-[linear-gradient(180deg,var(--color-brand-50)_0%,#fff_60%)]">
    <Container class="max-w-2xl py-(--spacing-section)">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Contact</h1>
      <p class="mt-3 text-lg text-slate-600">Een vraag, tip of opmerking? Laat het ons weten via het formulier hieronder.</p>
    </Container>
  </section>

  <Container class="max-w-2xl pb-(--spacing-section)">
    <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-5 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8">
      <input type="hidden" name="access_key" value={ACCESS_KEY} />
      <input type="hidden" name="subject" value="Nieuw bericht via AutoTheorieGratisOefenen" />
      <input type="hidden" name="from_name" value="AutoTheorieGratisOefenen" />
      <input type="hidden" name="redirect" data-redirect value="https://autotheorieoefenen.com/contact/thanks/" />
      <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div>
        <label for="name" class="block text-sm font-medium text-slate-800">Naam</label>
        <input id="name" name="name" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2.5 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-slate-800">E-mailadres</label>
        <input id="email" type="email" name="email" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2.5 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200" />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-slate-800">Bericht</label>
        <textarea id="message" name="message" rows="5" required minlength="10" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2.5 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"></textarea>
      </div>
      <div class="h-captcha" data-captcha="true"></div>

      <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-brand-700 px-6 py-3 font-semibold text-white transition hover:bg-brand-800">Versturen</button>
      <p class="text-xs text-slate-500">We gebruiken je gegevens alleen om je bericht te beantwoorden. Beschermd met hCaptcha.</p>
    </form>
  </Container>

  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    if (form) {
      const redirect = form.querySelector("[data-redirect]") as HTMLInputElement | null;
      if (redirect) redirect.value = window.location.origin + "/contact/thanks/";
      // Lazy-load web3forms script (enables optional hCaptcha) on first interaction
      let loaded = false;
      const load = () => {
        if (loaded) return; loaded = true;
        const s = document.createElement("script");
        s.src = "https://web3forms.com/client/script.js"; s.async = true; s.defer = true;
        document.head.appendChild(s);
      };
      form.addEventListener("focusin", load, { once: true });
      form.addEventListener("submit", load);
    }
  </script>
</BaseLayout>

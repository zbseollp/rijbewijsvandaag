---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import { getAllPosts, displayTitle } from "@lib/posts";

const posts = await getAllPosts();

const main = [
  { href: "/", title: "Home" },
  { href: "/blog/", title: "Blog" },
  { href: "/theorie-uitleg/", title: "Theorie uitleg" },
  { href: "/rijbewijs-halen/", title: "Rijbewijs halen" },
  { href: "/over-ons/", title: "Over ons" },
  { href: "/contact/", title: "Contact" },
];
---
<BaseLayout title="Sitemap | RijbewijsVandaag" description="Overzicht van alle pagina's en artikelen op RijbewijsVandaag.nl.">
  <Container class="py-(--spacing-section)">
    <div class="border-l-4 border-red-500 pl-5 mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Sitemap</h1>
    </div>

    <section class="mt-6">
      <h2 class="text-xl font-bold text-slate-900">Hoofdpagina's</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
        {main.map((p) => <li><a class="text-red-600 hover:underline font-medium" href={p.href}>{p.title}</a></li>)}
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">Blogartikelen ({posts.length})</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((p) => <li><a class="text-red-600 hover:underline" href={`/${p.id}/`}>{displayTitle(p)}</a></li>)}
      </ul>
    </section>
  </Container>
</BaseLayout>

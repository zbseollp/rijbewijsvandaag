---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import signsRaw from "../data/signs.json";

// Only signs with a usable name + image
const signs = (signsRaw as { id: string; name: string; image: string }[])
  .filter((s) => s.name && s.name.trim() && s.name.toLowerCase() !== "bord")
  .map((s) => ({ id: s.id, name: s.name.trim(), image: `/assets/images/signs/${s.id}.png` }));
---
<BaseLayout
  title="Verkeersborden oefenen — gratis bordenquiz | Autotheorieoefenen"
  description="Oefen gratis met alle Nederlandse verkeersborden. Test in 20 vragen of jij weet wat elk bord betekent. Direct beginnen, geen account nodig."
>
  <section class="bg-[linear-gradient(180deg,var(--color-brand-50)_0%,#fff_60%)]">
    <Container class="py-(--spacing-section)">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Verkeersborden oefenen</h1>
      <p class="mt-3 max-w-2xl text-lg text-slate-600">
        Test je kennis met 20 willekeurige verkeersborden. Klik op het juiste antwoord
        en zie meteen of het goed is. Helemaal gratis — geen account nodig.
      </p>
    </Container>
  </section>

  <Container class="pb-(--spacing-section)">
    <div id="quiz" class="mx-auto max-w-3xl rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <!-- Start screen -->
      <div data-screen="start">
        <p class="text-slate-600">Je krijgt 20 borden te zien. Probeer er zoveel mogelijk goed te raden!</p>
        <button data-action="start" class="mt-6 inline-flex items-center justify-center rounded-xl bg-brand-700 px-6 py-3 font-semibold text-white transition hover:bg-brand-800">
          Start de quiz
        </button>
      </div>

      <!-- Question screen -->
      <div data-screen="question" class="hidden">
        <div class="flex items-center justify-between text-sm font-medium text-slate-500">
          <span>🎓 Vraag <span data-current>1</span> / 20</span>
          <span>Score: <span data-score>0</span></span>
        </div>
        <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-slate-100">
          <div data-progress class="h-full bg-brand-500 transition-all" style="width:5%"></div>
        </div>

        <div class="mt-6 grid items-center gap-6 sm:grid-cols-2">
          <div class="flex justify-center">
            <img data-sign alt="Verkeersbord" width="220" height="220"
                 class="h-auto w-48 rounded-xl border border-slate-200 bg-white object-contain p-2 sm:w-56" />
          </div>
          <div>
            <h2 class="text-2xl font-extrabold text-slate-900">Wat betekent dit bord?</h2>
            <div data-options class="mt-4 flex flex-col gap-3"></div>
          </div>
        </div>

        <div class="mt-6 flex items-center justify-between">
          <p data-feedback class="text-sm font-semibold"></p>
          <button data-action="next" class="hidden rounded-xl bg-brand-700 px-6 py-3 font-semibold text-white transition hover:bg-brand-800">Volgende vraag</button>
        </div>
      </div>

      <!-- Result screen -->
      <div data-screen="result" class="hidden text-center">
        <h2 class="text-2xl font-extrabold text-slate-900">Klaar!</h2>
        <p class="mt-3 text-lg text-slate-600">Je had <span data-final class="font-extrabold text-brand-700">0</span> van de 20 goed.</p>
        <p data-verdict class="mt-1 text-slate-600"></p>
        <button data-action="restart" class="mt-6 inline-flex items-center justify-center rounded-xl bg-brand-700 px-6 py-3 font-semibold text-white transition hover:bg-brand-800">Opnieuw oefenen</button>
      </div>
    </div>

    <p class="mx-auto mt-6 max-w-3xl text-center text-sm text-slate-500">
      Wil je het volledige CBR-examen oefenen met gevaarherkenning en verkeerssituaties?
      Bekijk dan de uitgebreide <a class="font-semibold text-brand-700 hover:underline" href="https://www.autotheorie.nl" rel="nofollow noopener" target="_blank">premium examentraining</a>.
    </p>
  </Container>

  <script id="signs-data" type="application/json" set:html={JSON.stringify(signs)} is:inline></script>
  <script>
    type Sign = { id: string; name: string; image: string };
    const all: Sign[] = JSON.parse(document.getElementById("signs-data")!.textContent || "[]");
    const TOTAL = 20;
    const root = document.getElementById("quiz")!;
    const screens = {
      start: root.querySelector('[data-screen="start"]')!,
      question: root.querySelector('[data-screen="question"]')!,
      result: root.querySelector('[data-screen="result"]')!,
    };
    const el = {
      sign: root.querySelector("[data-sign]") as HTMLImageElement,
      options: root.querySelector("[data-options]")!,
      current: root.querySelector("[data-current]")!,
      score: root.querySelector("[data-score]")!,
      progress: root.querySelector("[data-progress]") as HTMLElement,
      feedback: root.querySelector("[data-feedback]")!,
      next: root.querySelector('[data-action="next"]') as HTMLButtonElement,
      final: root.querySelector("[data-final]")!,
      verdict: root.querySelector("[data-verdict]")!,
    };

    let deck: Sign[] = [];
    let idx = 0;
    let score = 0;
    let answered = false;

    const shuffle = <T,>(a: T[]): T[] => {
      const r = [...a];
      for (let i = r.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [r[i], r[j]] = [r[j], r[i]]; }
      return r;
    };
    const show = (name: keyof typeof screens) => {
      Object.entries(screens).forEach(([k, n]) => n.classList.toggle("hidden", k !== name));
    };

    function start() {
      deck = shuffle(all).slice(0, TOTAL);
      idx = 0; score = 0;
      el.score.textContent = "0";
      show("question");
      renderQuestion();
    }

    function renderQuestion() {
      answered = false;
      const sign = deck[idx];
      el.current.textContent = String(idx + 1);
      el.progress.style.width = `${((idx) / TOTAL) * 100 + 5}%`;
      el.sign.src = sign.image;
      el.sign.alt = "Verkeersbord";
      el.feedback.textContent = "";
      el.next.classList.add("hidden");

      // build 4 options: correct + 3 distractors (unique names)
      const distractors = shuffle(all.filter((s) => s.name !== sign.name))
        .reduce<string[]>((acc, s) => { if (acc.length < 3 && !acc.includes(s.name)) acc.push(s.name); return acc; }, []);
      const options = shuffle([sign.name, ...distractors]);

      el.options.innerHTML = "";
      for (const opt of options) {
        const b = document.createElement("button");
        b.type = "button";
        b.className = "flex items-center gap-3 rounded-xl border border-slate-200 px-4 py-3 text-left text-slate-800 transition hover:border-brand-400 hover:bg-brand-50";
        b.innerHTML = `<span class="grid h-5 w-5 place-items-center rounded-full border border-slate-300 text-xs"></span><span>${opt}</span>`;
        b.addEventListener("click", () => choose(b, opt, sign.name));
        el.options.appendChild(b);
      }
    }

    function choose(btn: HTMLButtonElement, picked: string, correct: string) {
      if (answered) return;
      answered = true;
      const buttons = [...el.options.querySelectorAll("button")] as HTMLButtonElement[];
      buttons.forEach((b) => (b.disabled = true));
      buttons.forEach((b) => {
        const label = b.textContent?.trim();
        if (label === correct) b.className = b.className.replace(/border-slate-200|hover:[^ ]+/g, "") + " border-green-500 bg-green-50 text-green-900";
      });
      if (picked === correct) {
        score++; el.score.textContent = String(score);
        el.feedback.textContent = "Goed! ✅"; el.feedback.className = "text-sm font-semibold text-green-700";
      } else {
        btn.className = btn.className.replace(/border-slate-200|hover:[^ ]+/g, "") + " border-red-500 bg-red-50 text-red-900";
        el.feedback.textContent = `Helaas — juiste antwoord: ${correct}`; el.feedback.className = "text-sm font-semibold text-red-700";
      }
      el.next.classList.remove("hidden");
    }

    function next() {
      idx++;
      if (idx >= TOTAL) return finish();
      renderQuestion();
    }

    function finish() {
      show("result");
      el.final.textContent = String(score);
      el.verdict.textContent = score >= 17 ? "Top! Je bent er klaar voor. 🎉"
        : score >= 12 ? "Goed bezig — nog even oefenen en je slaagt!"
        : "Blijf oefenen, je komt er wel! 💪";
    }

    root.querySelector('[data-action="start"]')?.addEventListener("click", start);
    el.next.addEventListener("click", next);
    root.querySelector('[data-action="restart"]')?.addEventListener("click", start);
  </script>
</BaseLayout>

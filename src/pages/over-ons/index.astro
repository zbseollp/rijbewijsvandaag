---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import { SITE } from "@lib/site";
---
<BaseLayout
  title={`Over ons | ${SITE.name}`}
  description="Wie zijn wij? RijbewijsVandaag.nl geeft gratis, praktische informatie voor iedereen die snel zijn rijbewijs B wil halen."
>
  <Container class="py-(--spacing-section)">
    <div class="mx-auto max-w-2xl">
      <div class="inline-flex items-center gap-2 rounded-full bg-orange-50 border border-orange-100 px-3 py-1 text-xs font-semibold text-orange-700 mb-5">
        Over RijbewijsVandaag.nl
      </div>
      <div class="border-l-4 border-red-500 pl-5 mb-8">
        <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Over ons</h1>
      </div>
      <div class="space-y-5 text-slate-600 leading-relaxed">
        <p>RijbewijsVandaag.nl is een gratis informatieplatform voor iedereen die zijn rijbewijs B wil halen — zo snel en goed mogelijk voorbereid. We schrijven praktische artikelen over het CBR theorie-examen, verkeersregels, gevaarherkenning en rijbewijs halen in Nederland.</p>
        <p>Onze artikelen zijn gericht op mensen die concreet en doelgericht willen leren: geen saaie theorieboeken, maar heldere uitleg die direct klaar maakt voor het examen. We leggen voorrangsregels, verkeersborden en rijbewijs-procedures stap voor stap uit.</p>
        <p>Alles op deze site is gratis toegankelijk — geen account nodig, geen abonnement.</p>
        <p>Heb je een vraag of opmerking? Neem contact met ons op via de <a href="/contact/" class="text-red-600 font-medium underline underline-offset-2">contactpagina</a>.</p>
      </div>
    </div>
  </Container>
</BaseLayout>

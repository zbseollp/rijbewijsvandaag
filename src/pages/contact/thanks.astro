---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
---
<BaseLayout title="Bedankt voor je bericht | Autotheorieoefenen" description="Je bericht is verstuurd." noindex={true}>
  <Container class="max-w-2xl py-(--spacing-section) text-center">
    <div class="mx-auto grid h-16 w-16 place-items-center rounded-full bg-green-100 text-green-700 text-2xl">✓</div>
    <h1 class="mt-6 text-3xl font-extrabold text-slate-900">Bedankt voor je bericht!</h1>
    <p class="mt-3 text-slate-600">We hebben je bericht ontvangen en nemen zo snel mogelijk contact op.</p>
    <div class="mt-8 flex justify-center gap-3">
      <Button href="/" variant="primary">Terug naar home</Button>
      <Button href="/verkeersborden-oefenen/" variant="secondary">Verder oefenen</Button>
    </div>
  </Container>
</BaseLayout>
